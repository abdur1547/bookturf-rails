<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
      }
      .password-box {
        font-size: 20px;
        font-weight: bold;
        color: #2563eb;
        letter-spacing: 2px;
        text-align: center;
        padding: 16px;
        background-color: #f3f4f6;
        border-radius: 8px;
        margin: 20px 0;
      }
      .btn {
        display: inline-block;
        padding: 12px 24px;
        background-color: #2563eb;
        color: #ffffff;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
      }
      .footer {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e5e7eb;
        font-size: 12px;
        color: #6b7280;
      }
    </style>
  </head>
  <body>
    <h2>Welcome to <%= @venue.name %></h2>

    <p>Hello <%= @user.full_name %>,</p>

    <p>You've been added as a staff member at <strong><%= @venue.name %></strong>.</p>

    <% if @temp_password.present? %>
      <p>Your temporary login credentials are:</p>
      <p><strong>Email:</strong> <%= @user.email %></p>
      <div class="password-box"><%= @temp_password %></div>
      <p>Please log in and change your password as soon as possible.</p>
    <% else %>
      <p>Use your existing credentials to log in.</p>
    <% end %>

    <p style="text-align: center; margin: 30px 0;">
      <a href="<%= @login_url %>" class="btn">Log in to Bookturf</a>
    </p>

    <div class="footer">
      <p>This is an automated email. Please do not reply to this message.</p>
    </div>
  </body>
</html>
