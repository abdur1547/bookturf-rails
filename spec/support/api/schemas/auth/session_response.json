{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean",
      "enum": [true]
    },
    "data": {
      "$ref": "#/definitions/user"
    }
  },
  "definitions": {
    "user": {
      "type": "object",
      "required": ["id", "full_name", "email", "system_role"],
      "properties": {
        "id": { "type": "integer" },
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "avatar_url": { "type": ["string", "null"] },
        "phone_number": { "type": ["string", "null"] },
        "system_role": { "type": "string", "enum": ["normal", "super_admin"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    }
  }
}
