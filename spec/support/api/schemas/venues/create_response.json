{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "success",
        "data"
    ],
    "properties": {
        "success": {
            "type": "boolean",
            "enum": [
                true
            ]
        },
        "data": {
            "$ref": "#/definitions/venue_detail"
        }
    },
    "definitions": {
        "venue_detail": {
            "type": "object",
            "required": [
                "id",
                "name",
                "slug",
                "address",
                "is_active",
                "created_at",
                "updated_at",
                "owner",
                "venue_setting",
                "venue_operating_hours",
                "courts_count"
            ],
            "properties": {
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "slug": {
                    "type": "string"
                },
                "description": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "address": {
                    "type": "string"
                },
                "city": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "state": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "country": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "postal_code": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "phone_number": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "email": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "latitude": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "longitude": {
                    "type": [
                        "number",
                        "null"
                    ]
                },
                "is_active": {
                    "type": "boolean"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "google_maps_url": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "courts_count": {
                    "type": "integer"
                },
                "owner": {
                    "$ref": "#/definitions/user_minimal"
                },
                "venue_setting": {
                    "$ref": "#/definitions/venue_setting"
                },
                "venue_operating_hours": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/venue_operating_hour"
                    }
                }
            }
        },
        "user_minimal": {
            "type": "object",
            "required": [
                "id",
                "email",
                "name"
            ],
            "properties": {
                "id": {
                    "type": "integer"
                },
                "email": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "venue_setting": {
            "type": "object",
            "required": [
                "id",
                "minimum_slot_duration",
                "maximum_slot_duration",
                "slot_interval",
                "advance_booking_days",
                "requires_approval",
                "timezone",
                "currency"
            ],
            "properties": {
                "id": {
                    "type": "integer"
                },
                "minimum_slot_duration": {
                    "type": "integer"
                },
                "maximum_slot_duration": {
                    "type": "integer"
                },
                "slot_interval": {
                    "type": "integer"
                },
                "advance_booking_days": {
                    "type": "integer"
                },
                "requires_approval": {
                    "type": "boolean"
                },
                "cancellation_hours": {
                    "type": [
                        "integer",
                        "null"
                    ]
                },
                "timezone": {
                    "type": "string"
                },
                "currency": {
                    "type": "string"
                }
            }
        },
        "venue_operating_hour": {
            "type": "object",
            "required": [
                "id",
                "day_of_week",
                "is_closed",
                "day_name",
                "formatted_hours"
            ],
            "properties": {
                "id": {
                    "type": "integer"
                },
                "day_of_week": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 6
                },
                "opens_at": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "closes_at": {
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "is_closed": {
                    "type": "boolean"
                },
                "day_name": {
                    "type": "string"
                },
                "formatted_hours": {
                    "type": "string"
                }
            }
        }
    }
}