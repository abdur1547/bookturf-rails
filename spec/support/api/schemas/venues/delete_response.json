{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": [
        "success",
        "data"
    ],
    "properties": {
        "success": {
            "type": "boolean",
            "enum": [
                true
            ]
        },
        "data": {
            "type": "object",
            "required": [
                "message"
            ],
            "properties": {
                "message": {
                    "type": "string"
                }
            }
        }
    }
}