{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["success", "data"],
  "properties": {
    "success": {
      "type": "boolean",
      "enum": [true]
    },
    "data": { "$ref": "#/definitions/role" }
  },
  "definitions": {
    "role": {
      "type": "object",
      "required": ["id", "name", "venue_id", "created_at", "updated_at", "permissions"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "venue_id": { "type": "integer" },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "permissions": {
          "type": "array",
          "items": { "$ref": "#/definitions/permission" }
        }
      }
    },
    "permission": {
      "type": "object",
      "required": ["id", "resource", "action"],
      "properties": {
        "id": { "type": "integer" },
        "resource": { "type": "string" },
        "action": { "type": "string" }
      }
    }
  }
}
